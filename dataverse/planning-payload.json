    { "type": "ManyToOne", "fromTable": "pt_project", "toTable": "systemuser", "referencingEntity": "pt_project", "referencedEntity": "systemuser", "schemaName": "pt_Project_Lead", "lookupSchemaName": "pt_projectlead", "lookupDisplayName": "Project Lead", "cascade": "Referential" },
    { "type": "ManyToOne", "fromTable": "pt_assignment", "toTable": "pt_project", "referencingEntity": "pt_assignment", "referencedEntity": "pt_project", "schemaName": "pt_Project_Assignment", "lookupSchemaName": "pt_project", "lookupDisplayName": "Project", "cascade": "Cascade" },
    { "type": "ManyToOne", "fromTable": "pt_assignment", "toTable": "pt_resource", "referencingEntity": "pt_assignment", "referencedEntity": "pt_resource", "schemaName": "pt_Resource_Assignment", "lookupSchemaName": "pt_resource", "lookupDisplayName": "Resource", "cascade": "Restrict" },
    { "type": "ManyToOne", "fromTable": "pt_resource", "toTable": "systemuser", "referencingEntity": "pt_resource", "referencedEntity": "systemuser", "schemaName": "pt_Resource_Owner", "lookupSchemaName": "pt_owner", "lookupDisplayName": "Owner", "cascade": "Referential" }
