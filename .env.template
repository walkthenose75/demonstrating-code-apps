# .env - Environment configuration for this Power Apps Code App.
# Copy to `.env` and fill in. This file is committed as a scaffold; `.env` holds
# your real values. NEVER put a client secret in a committed file — keep secrets
# only in `.env` (which is safe to keep local) or a secret store.

# ---- Power Platform environment URLs (from the Admin Center) ----
PP_ENV_DEV=https://your-dev.crm.dynamics.com
PP_ENV_TEST=https://your-test.crm.dynamics.com
PP_ENV_PROD=https://your-prod.crm.dynamics.com

# ---- Publisher / solution identity ----
PP_PUBLISHER_PREFIX=pt
SOLUTION_UNIQUE_NAME=ProjectTracker

# ---- Dataverse provisioning auth (used by `npm run provision`) ----
# Your Entra tenant (GUID or verified domain). Required for device-code auth.
PP_TENANT_ID=

# OPTION A (recommended, low-friction, headless): Service Principal.
# Create an App Registration, add a client secret, and register it as an
# Application User (System Administrator) in the target environment. Then the
# provisioner runs with zero interactive prompts.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OPTION B (fallback): leave the AZURE_* values blank and the provisioner uses
# device-code sign-in (one interactive sign-in; token is then cached).
